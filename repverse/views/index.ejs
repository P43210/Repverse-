<!-- ── TESTIMONIALS ───────────────────────────────────────────── -->
<section class="section reveal" id="testimonials">
  <div class="section-header">
    <div class="section-tag">Community</div>
    <h2 class="section-title">What Contributors Say</h2>
  </div>
  <div class="testimonials-grid">
    <div class="card testimonial-card reveal">
      <div class="testimonial-quote">"REPVERSE finally gives me a way to show my work beyond just a GitHub link. My trust grade is something I'm actually proud to share with DAOs."</div>
      <div class="testimonial-author">
        <div class="testimonial-avatar">AK</div>
        <div>
          <div class="testimonial-name">pale.btc</div>
          <div class="testimonial-role">Smart Contract Auditor · Zero Authority DAO</div>
        </div>
      </div>
