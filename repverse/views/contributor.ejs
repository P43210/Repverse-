<%- include('partials/header') %>

<section class="section" style="max-width:900px;margin:0 auto">

  <!-- Back Button -->
  <div style="margin-bottom:32px">
    <a href="/" class="btn btn-secondary btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Back
    </a>
  </div>

  <!-- Profile Header -->
  <div class="card" style="padding:32px;margin-bottom:24px">
    <div class="result-profile-header">
      <div class="result-avatar" style="width:80px;height:80px;font-size:1.6rem">
        <% if (profile.avatar) { %>
          <img src="<%= profile.avatar %>" alt="<%= profile.username %>" onerror="this.parentElement.textContent='<%= profile.username.substring(0,2).toUpperCase() %>'">
        <% } else { %>
          <%= profile.username.substring(0,2).toUpperCase() %>
        <% } %>
      </div>
      <div style="flex:1">
        <div class="result-name" style="font-size:1.75rem">
          <%= profile.username %>
          <% if (profile.isVerified) { %>
            <span class="verified-badge" style="color:var(--accent-blue)">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </span>
          <% } %>
        </div>
        <% if (profile.wallet) { %>
          <div class="result-wallet"><%= profile.wallet %></div>
        <% } %>
        <% if (profile.bio) { %>
          <div style="font-size:0.9rem;color:var(--text-secondary);margin-top:10px;line-height:1.6"><%= profile.bio %></div>
        <% } %>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:12px">
          <% if (profile.githubUrl) { %>
            <a href="<%= profile.githubUrl %>" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          <% } %>
          <% if (profile.twitterUrl) { %>
            <a href="<%= profile.twitterUrl %>" target="_blank" rel="noopener" class="btn btn-secondary btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Twitter
            </a>
          <% } %>
          <a href="https://zeroauthoritydao.com/creators/<%= encodeURIComponent(profile.username) %>" target="_blank" rel="noopener" class="btn btn-outline btn-sm">
            View on Zero Authority ↗
          </a>
        </div>
      </div>
      <div>
        <div class="trust-score-badge trust-<%= trust.grade.toLowerCase() %>" style="flex-direction:column;align-items:center;gap:4px;padding:16px 20px">
          <div style="font-family:var(--font-display);font-size:2rem;font-weight:800"><%= trust.grade %></div>
          <div style="font-size:0.7rem;letter-spacing:0.1em">TRUST GRADE</div>
          <div style="font-size:0.85rem;font-weight:700"><%= trust.score %>/100</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="result-stats-grid" style="margin-bottom:24px">
    <div class="result-stat">
      <div class="result-stat-value"><%= profile.reputationScore || trust.score %></div>
      <div class="result-stat-label">Reputation</div>
    </div>
    <div class="result-stat">
      <div class="result-stat-value"><%= profile.bountiesCompleted %></div>
      <div class="result-stat-label">Bounties</div>
    </div>
    <div class="result-stat">
      <div class="result-stat-value"><%= profile.questsCompleted %></div>
      <div class="result-stat-label">Quests</div>
    </div>
    <div class="result-stat">
      <div class="result-stat-value"><%= profile.gigsCompleted %></div>
      <div class="result-stat-label">Gigs</div>
    </div>
    <div class="result-stat">
      <div class="result-stat-value"><%= profile.endorsements %></div>
      <div class="result-stat-label">Endorsements</div>
    </div>
    <div class="result-stat">
      <div class="result-stat-value"><%= profile.governanceVotes %></div>
      <div class="result-stat-label">Gov Votes</div>
    </div>
  </div>

  <!-- AI Summary -->
  <div class="ai-summary" style="margin-bottom:24px">
    <div class="ai-summary-header">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" style="color:var(--accent-blue)"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
      <span class="ai-label">AI Reputation Analysis</span>
    </div>
    <div class="ai-summary-text"><%= aiSummary %></div>
  </div>

  <!-- Contribution Heatmap -->
  <div class="card" style="margin-bottom:24px;padding:28px">
    <div style="font-size:0.8rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:16px">Contribution Activity (Past Year)</div>
    <div class="heatmap-grid" id="heatmap-container"></div>
    <div style="display:flex;align-items:center;gap:8px;margin-top:12px;font-size:0.75rem;color:var(--text-muted)">
      Less
      <div style="display:flex;gap:3px">
        <div class="heatmap-cell"></div>
        <div class="heatmap-cell level-1"></div>
        <div class="heatmap-cell level-2"></div>
        <div class="heatmap-cell level-3"></div>
        <div class="heatmap-cell level-4"></div>
      </div>
      More
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px">
    <!-- Score Breakdown -->
    <div class="card" style="padding:24px">
      <div style="font-size:0.8rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:20px">Score Breakdown</div>
      <% Object.entries(trust.breakdown || {}).forEach(([key, val]) => { %>
        <div style="margin-bottom:14px">
          <div style="display:flex;justify-content:space-between;font-size:0.875rem;margin-bottom:6px">
            <span><%= key %></span>
            <span style="font-family:var(--font-mono);color:var(--accent-blue)"><%= val %></span>
          </div>
          <div class="progress-bar">
            <div class="progress-fill" data-width="<%= Math.min(100, (val / 100) * 100) %>" style="width:0%"></div>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- DAO Involvement -->
    <div class="card" style="padding:24px">
      <div style="font-size:0.8rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:20px">DAO Involvement</div>
      <% if (Array.isArray(profile.daos) && profile.daos.length > 0) { %>
        <div class="tags-list">
          <% profile.daos.slice(0,10).forEach(d => { %>
            <span class="tag" style="padding:6px 14px"><%= typeof d === 'string' ? d : (d.name || d) %></span>
          <% }); %>
        </div>
      <% } else { %>
        <p style="color:var(--text-muted);font-size:0.875rem">No DAO memberships listed.</p>
      <% } %>

      <% if (Array.isArray(profile.skills) && profile.skills.length > 0) { %>
        <div style="margin-top:20px">
          <div style="font-size:0.8rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:12px">Skills</div>
          <div class="tags-list">
            <% profile.skills.slice(0,8).forEach(s => { %>
              <span class="tag"><%= s %></span>
            <% }); %>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Joined info -->
  <% if (profile.joinedAt) { %>
    <div style="text-align:center;font-size:0.8rem;color:var(--text-muted);margin-bottom:40px">
      Member since <%= new Date(profile.joinedAt).toLocaleDateString('en-US', { year:'numeric', month:'long' }) %>
    </div>
  <% } %>

</section>

<script>
// Generate heatmap
const heatmap = document.getElementById('heatmap-container');
if (heatmap) {
  for (let i = 0; i < 52 * 7; i++) {
    const r = Math.random();
    let level = 0;
    if (r > 0.85) level = 4;
    else if (r > 0.72) level = 3;
    else if (r > 0.6) level = 2;
    else if (r > 0.5) level = 1;
    const cell = document.createElement('div');
    cell.className = `heatmap-cell level-${level}`;
    heatmap.appendChild(cell);
  }
}

// Animate progress bars
setTimeout(() => {
  document.querySelectorAll('.progress-fill').forEach(bar => {
    bar.style.width = bar.dataset.width + '%';
  });
}, 300);
</script>

<%- include('partials/footer') %>
